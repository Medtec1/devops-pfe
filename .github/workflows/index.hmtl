<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My DevOps PFE</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Syne', sans-serif;
      background: #0a0e1a;
      color: #e2e8f0;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }

    .grid-bg {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(55,138,221,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(55,138,221,0.07) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .glow-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
    }
    .orb1 { width: 400px; height: 400px; background: #378ADD; top: -100px; left: -80px; }
    .orb2 { width: 300px; height: 300px; background: #1D9E75; bottom: 80px; right: -60px; }
    .orb3 { width: 200px; height: 200px; background: #534AB7; top: 50%; left: 60%; }

    .hero {
      position: relative;
      z-index: 2;
      padding: 5rem 2rem 2rem;
      text-align: center;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(55,138,221,0.12);
      border: 0.5px solid rgba(55,138,221,0.35);
      border-radius: 999px;
      padding: 6px 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: #85B7EB;
      margin-bottom: 2rem;
      letter-spacing: 0.08em;
      animation: fadeDown 0.6s ease both;
    }

    .badge-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #1D9E75;
      box-shadow: 0 0 6px #1D9E75;
      animation: pulse 1.8s infinite;
    }

    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    h1.main-title {
      font-size: clamp(2.4rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.2rem;
      animation: fadeUp 0.7s 0.1s ease both;
    }

    .highlight { color: #378ADD; }
    .highlight-green { color: #5DCAA5; }

    .subtitle {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: #888780;
      margin-bottom: 3rem;
      letter-spacing: 0.05em;
      animation: fadeUp 0.7s 0.2s ease both;
    }

    .pipeline {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      margin-bottom: 3.5rem;
      animation: fadeUp 0.7s 0.3s ease both;
      position: relative;
      z-index: 2;
      padding: 0 1rem;
    }

    .pipe-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .pipe-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
      border: 0.5px solid;
      transition: transform 0.2s;
      cursor: default;
    }
    .pipe-icon:hover { transform: translateY(-4px); }
    .pipe-icon.blue   { background: rgba(55,138,221,0.12); border-color: rgba(55,138,221,0.3); }
    .pipe-icon.teal   { background: rgba(29,158,117,0.12); border-color: rgba(29,158,117,0.3); }
    .pipe-icon.purple { background: rgba(83,74,183,0.12);  border-color: rgba(83,74,183,0.3); }
    .pipe-icon.coral  { background: rgba(216,90,48,0.12);  border-color: rgba(216,90,48,0.3); }
    .pipe-icon.amber  { background: rgba(186,117,23,0.12); border-color: rgba(186,117,23,0.3); }

    .pipe-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: #5F5E5A;
      letter-spacing: 0.05em;
    }

    .pipe-arrow {
      width: 28px; height: 2px;
      background: linear-gradient(90deg, rgba(55,138,221,0.4), rgba(29,158,117,0.4));
      position: relative;
      margin: 0 2px;
      margin-bottom: 24px;
      flex-shrink: 0;
    }
    .pipe-arrow::after {
      content: '';
      position: absolute;
      right: -4px; top: -3px;
      border: 4px solid transparent;
      border-left-color: rgba(29,158,117,0.5);
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      max-width: 860px;
      margin: 0 auto 3rem;
      padding: 0 1.5rem;
      animation: fadeUp 0.7s 0.4s ease both;
      position: relative; z-index: 2;
    }

    .card {
      background: rgba(255,255,255,0.03);
      border: 0.5px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 1.2rem;
      transition: border-color 0.2s, background 0.2s;
      cursor: default;
    }
    .card:hover {
      border-color: rgba(55,138,221,0.3);
      background: rgba(55,138,221,0.05);
    }

    .card-num   { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #444441; margin-bottom: 8px; }
    .card-title { font-size: 15px; font-weight: 700; color: #e2e8f0; margin-bottom: 6px; }
    .card-desc  { font-size: 12px; color: #5F5E5A; line-height: 1.6; font-family: 'JetBrains Mono', monospace; }

    .card-tag {
      display: inline-block;
      margin-top: 10px;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 10px;
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.05em;
    }
    .tag-blue   { background: rgba(55,138,221,0.12); color: #85B7EB; }
    .tag-teal   { background: rgba(29,158,117,0.12); color: #5DCAA5; }
    .tag-purple { background: rgba(83,74,183,0.12);  color: #AFA9EC; }
    .tag-coral  { background: rgba(216,90,48,0.12);  color: #F0997B; }

    .terminal-wrap {
      max-width: 560px;
      margin: 0 auto 2.5rem;
      position: relative; z-index: 2;
      animation: fadeUp 0.7s 0.45s ease both;
      padding: 0 1.5rem;
    }

    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.04);
      border: 0.5px solid rgba(255,255,255,0.08);
      border-radius: 10px 10px 0 0;
      padding: 8px 14px;
    }
    .t-dot { width: 10px; height: 10px; border-radius: 50%; }
    .t-red   { background: #A32D2D; }
    .t-amber { background: #854F0B; }
    .t-green { background: #3B6D11; }
    .terminal-title-text { font-size: 11px; color: #444441; margin-left: 6px; font-family: 'JetBrains Mono', monospace; }

    .terminal-body {
      background: rgba(0,0,0,0.35);
      border: 0.5px solid rgba(255,255,255,0.06);
      border-top: none;
      border-radius: 0 0 10px 10px;
      padding: 14px 18px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      text-align: left;
      line-height: 2;
    }
    .t-green-text { color: #5DCAA5; }
    .t-blue-text  { color: #85B7EB; }
    .t-muted      { color: #444441; }

    .cursor {
      display: inline-block;
      width: 8px; height: 14px;
      background: #85B7EB;
      vertical-align: middle;
      animation: blink 1s infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    .footer-line {
      position: relative; z-index: 2;
      text-align: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: #444441;
      padding-bottom: 3rem;
      animation: fadeUp 0.7s 0.5s ease both;
    }

    @keyframes fadeUp   { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeDown { from{opacity:0;transform:translateY(-10px)} to{opacity:1;transform:translateY(0)} }
  </style>
</head>
<body>

  <div class="grid-bg"></div>
  <div class="glow-orb orb1"></div>
  <div class="glow-orb orb2"></div>
  <div class="glow-orb orb3"></div>

  <div class="hero">
    <div class="badge">
      <div class="badge-dot"></div>
      Projet de Fin d'Études &nbsp;·&nbsp; DevOps
    </div>
    <h1 class="main-title">
      My <span class="highlight">DevOps</span><br>
      <span class="highlight-green">PFE</span> Project
    </h1>
    <p class="subtitle">// CI/CD · Containerization · Infrastructure as Code · Monitoring</p>
  </div>

  <div class="pipeline">
    <div class="pipe-step">
      <div class="pipe-icon blue">&#128196;</div>
      <span class="pipe-label">CODE</span>
    </div>
    <div class="pipe-arrow"></div>
    <div class="pipe-step">
      <div class="pipe-icon teal">&#9881;</div>
      <span class="pipe-label">BUILD</span>
    </div>
    <div class="pipe-arrow"></div>
    <div class="pipe-step">
      <div class="pipe-icon purple">&#128202;</div>
      <span class="pipe-label">TEST</span>
    </div>
    <div class="pipe-arrow"></div>
    <div class="pipe-step">
      <div class="pipe-icon coral">&#128230;</div>
      <span class="pipe-label">DEPLOY</span>
    </div>
    <div class="pipe-arrow"></div>
    <div class="pipe-step">
      <div class="pipe-icon amber">&#128065;</div>
      <span class="pipe-label">MONITOR</span>
    </div>
  </div>

  <div class="cards">
    <div class="card">
      <div class="card-num">01</div>
      <div class="card-title">CI/CD Pipeline</div>
      <div class="card-desc">Automated build, test & delivery with GitHub Actions</div>
      <span class="card-tag tag-blue">Jenkins / GitHub Actions</span>
    </div>
    <div class="card">
      <div class="card-num">02</div>
      <div class="card-title">Containerization</div>
      <div class="card-desc">Docker & Kubernetes for scalable microservices</div>
      <span class="card-tag tag-teal">Docker · K8s</span>
    </div>
    <div class="card">
      <div class="card-num">03</div>
      <div class="card-title">Infrastructure as Code</div>
      <div class="card-desc">Terraform & Ansible for repeatable environments</div>
      <span class="card-tag tag-purple">Terraform · Ansible</span>
    </div>
    <div class="card">
      <div class="card-num">04</div>
      <div class="card-title">Monitoring & Logs</div>
      <div class="card-desc">Observability stack with Prometheus & Grafana</div>
      <span class="card-tag tag-coral">Prometheus · Grafana</span>
    </div>
  </div>

  <div class="terminal-wrap">
    <div class="terminal-bar">
      <div class="t-dot t-red"></div>
      <div class="t-dot t-amber"></div>
      <div class="t-dot t-green"></div>
      <span class="terminal-title-text">bash — pipeline status</span>
    </div>
    <div class="terminal-body">
      <span class="t-green-text">✔</span> <span class="t-muted">build</span> &nbsp;&nbsp;&nbsp;completed in 42s<br>
      <span class="t-green-text">✔</span> <span class="t-muted">test</span> &nbsp;&nbsp;&nbsp;12/12 passed<br>
      <span class="t-green-text">✔</span> <span class="t-muted">deploy</span> &nbsp;production — <span class="t-blue-text">v1.0.0</span><br>
      <span class="t-muted">$</span> <span class="cursor"></span>
    </div>
  </div>

  <div class="footer-line">
    &copy; 2025 &nbsp;·&nbsp; Built with passion &amp; pipelines
  </div>

</body>
</html>
